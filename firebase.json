{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".github",
      ".gitignore",
      ".claude",
      "node_modules",
      "package.json",
      "package-lock.json",
      "_build",
      "README.md"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=()"
          },
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/demos",
        "destination": "/thicket/demos.html",
        "type": 301
      },
      {
        "source": "/demos.html",
        "destination": "/thicket/demos.html",
        "type": 301
      },
      {
        "source": "/compare",
        "destination": "/thicket/compare.html",
        "type": 301
      },
      {
        "source": "/compare.html",
        "destination": "/thicket/compare.html",
        "type": 301
      },
      {
        "source": "/how-it-works",
        "destination": "/thicket/how-it-works.html",
        "type": 301
      },
      {
        "source": "/how-it-works.html",
        "destination": "/thicket/how-it-works.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/thicket",
        "destination": "/thicket/index.html"
      },
      {
        "source": "/rowan",
        "destination": "/rowan/index.html"
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}